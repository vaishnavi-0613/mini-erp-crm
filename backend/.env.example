# Server
PORT=4000
NODE_ENV=development

# Database (PostgreSQL connection string)
# Local example:    postgresql://postgres:postgres@localhost:5432/mini_erp_crm?schema=public
# Neon/Supabase/Render Postgres: paste the connection string they give you here
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mini_erp_crm?schema=public"

# Auth
JWT_SECRET="change-this-to-a-long-random-string"
JWT_EXPIRES_IN="8h"

# CORS - comma separated list of allowed frontend origins
CORS_ORIGIN="http://localhost:5173"
